{
  "name": "oh-my-skills",
  "version": "0.1.8",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "lefthook install",
    "check-types": "tsc --noEmit",
    "check": "biome check --write --unsafe",
    "test": "bun test",
    "docker:build": "docker build -t oh-my-skills .",
    "predocker:run": "bun docker:build",
    "docker:run": "docker run -it --rm oh-my-skills bash"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "testcontainers": "11.12.0",
    "@biomejs/biome": "2.4.3",
    "lefthook": "2.1.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
