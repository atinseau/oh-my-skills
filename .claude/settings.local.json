{
  "permissions": {
    "allow": [
      "WebSearch",
      "Bash(bun install:*)",
      "Bash(bun test:*)",
      "Bash(docker:*)",
      "WebFetch(domain:testcontainers.com)",
      "WebFetch(domain:node.testcontainers.org)",
      "Bash(sed:*)",
      "Bash(chmod +x:*)",
      "Bash(bash:*)",
      "Bash(TESTCONTAINERS_RYUK_DISABLED=true bun test:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(bun check-types:*)",
      "Bash(bun run:*)",
      "Bash(git reset:*)"
    ]
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true
  }
}
